<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
             x:Class="PharmacyWarehouse.Views.IncomingInvoicesView">

    <DockPanel Margin="15">
        <Button DockPanel.Dock="Top" 
                Content="➕ Добавить приходную накладную" 
                HorizontalAlignment="Left" 
                Margin="0,0,0,15"
                Click="AddIncoming_Click" 
                Height="40" Width="260" FontSize="14"/>

        <DataGrid ItemsSource="{Binding IncomingInvoices}" 
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="All"/>
    </DockPanel>
</UserControl>