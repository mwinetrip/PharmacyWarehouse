<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PharmacyWarehouse.Views.AddMedicineWindow"
        Width="400"
        Height="400"
        Title="Добавить лекарство">

    <StackPanel Margin="10" Spacing="5">

        <TextBox Name="NameBox" Watermark="Название"/>
        <TextBox Name="CategoryBox" Watermark="Категория"/>
        <TextBox Name="ManufacturerBox" Watermark="Производитель"/>
        <TextBox Name="PackageBox" Watermark="Упаковка"/>

        <Button Content="Сохранить"
                Click="Save_Click"/>

    </StackPanel>

</Window>