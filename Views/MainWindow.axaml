<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PharmacyWarehouse.ViewModels"
        xmlns:views="using:PharmacyWarehouse.Views"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
        x:Class="PharmacyWarehouse.Views.MainWindow"
        Title="Аптечный склад — Информационная система"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <TabControl Margin="10" TabStripPlacement="Top">

        <TabItem Header="Лекарства">
            <views:MedicinesView DataContext="{Binding MedicinesVM}"/>
        </TabItem>

        <TabItem Header="Поставщики">
            <views:SuppliersView DataContext="{Binding SuppliersVM}"/>
        </TabItem>

        <TabItem Header="Покупатели">
            <views:CustomersView DataContext="{Binding CustomersVM}"/>
        </TabItem>

        <TabItem Header="Приход на склад">
            <views:IncomingInvoicesView DataContext="{Binding IncomingVM}"/>
        </TabItem>

        <TabItem Header="Счета-фактуры (Расход)">
            <views:SalesInvoicesView DataContext="{Binding SalesVM}"/>
        </TabItem>

    </TabControl>
</Window>