<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dg="using:Avalonia.Controls"
             xmlns:vm="using:PharmacyWarehouse.ViewModels.Pages"
             mc:Ignorable="d"
             x:Class="PharmacyWarehouse.Views.SuppliersView"
             x:DataType="vm:SuppliersViewModel">

    <DockPanel Margin="15">
        <Button DockPanel.Dock="Top" 
                Content="➕ Добавить поставщика" 
                HorizontalAlignment="Left" 
                Margin="0,0,0,15"
                Click="AddSupplier_Click" 
                Height="42" 
                Width="280" />

        <dg:DataGrid ItemsSource="{Binding Suppliers}" 
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     GridLinesVisibility="All"
                     CanUserResizeColumns="True">

            <dg:DataGrid.Columns>
                <dg:DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <dg:DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="320"/>
                <dg:DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="140"/>
                <dg:DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="160"/>
                <dg:DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="300"/>
                <dg:DataGridTextColumn Header="Банк" Binding="{Binding Bank}" Width="180"/>
                <dg:DataGridTextColumn Header="Расчётный счёт" Binding="{Binding AccountNumber}" Width="200"/>
            </dg:DataGrid.Columns>
        </dg:DataGrid>
    </DockPanel>
</UserControl>