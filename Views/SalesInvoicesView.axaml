<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dg="using:Avalonia.Controls"
             xmlns:vm="using:PharmacyWarehouse.ViewModels.Pages"
             mc:Ignorable="d"
             x:Class="PharmacyWarehouse.Views.SalesInvoicesView"
             x:DataType="vm:SalesInvoicesViewModel">

    <DockPanel Margin="15">
        <Button DockPanel.Dock="Top" 
                Content="➕ Выписать счёт-фактуру" 
                HorizontalAlignment="Left" 
                Margin="0,0,0,15"
                Click="AddSales_Click" 
                Height="42" 
                Width="280" />

        <dg:DataGrid ItemsSource="{Binding SalesInvoices}" 
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     GridLinesVisibility="All"
                     CanUserResizeColumns="True">

            <dg:DataGrid.Columns>
                <dg:DataGridTextColumn Header="№ счёта" Binding="{Binding InvoiceNumber}" Width="150"/>
                <dg:DataGridTextColumn Header="Дата выписки" Binding="{Binding IssueDate, StringFormat=dd.MM.yyyy}" Width="140"/>
                <dg:DataGridTextColumn Header="Покупатель" Binding="{Binding Customer.Name}" Width="280"/>
                <dg:DataGridTextColumn Header="Кол-во позиций" Binding="{Binding Items.Count}" Width="110"/>
                <dg:DataGridTextColumn Header="Общая сумма" Binding="{Binding TotalAmount, StringFormat='0.00 ₽'}" Width="140"/>
                <dg:DataGridTextColumn Header="Продавец" Binding="{Binding SellerName}" Width="160"/>
            </dg:DataGrid.Columns>
        </dg:DataGrid>
    </DockPanel>
</UserControl>