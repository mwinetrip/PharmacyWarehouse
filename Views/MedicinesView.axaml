<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
             x:Class="PharmacyWarehouse.Views.MedicinesView"
             xmlns:vm="using:PharmacyWarehouse.ViewModels.Pages">

    <DockPanel Margin="10">
        <Button DockPanel.Dock="Top" Content="Добавить лекарство" 
                HorizontalAlignment="Left" Margin="0,0,0,10"
                Click="AddMedicine_Click" Height="38" Width="200" FontSize="14"/>

        <DataGrid ItemsSource="{Binding Medicines}" 
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Margin="0,10,0,0"/>
    </DockPanel>
</UserControl>