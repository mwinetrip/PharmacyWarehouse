<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="550"
             x:Class="PharmacyWarehouse.Views.MedicinesView">

    <DockPanel Margin="10">
        <Button DockPanel.Dock="Top" Content="Добавить лекарство" 
                HorizontalAlignment="Left" Margin="0,0,0,10"
                Click="AddMedicine_Click" Height="35" Width="180"/>

        <!-- Пока просто заглушка. Позже сюда добавим DataGrid -->
        <TextBlock Text="Список лекарств будет здесь (DataGrid)" 
                   VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16"/>
    </DockPanel>
</UserControl>